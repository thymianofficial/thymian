{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../plugins/sampler/tsconfig.lib.json"
    },
    {
      "path": "../core/tsconfig.lib.json"
    },
    {
      "path": "../plugins/websocket-proxy/tsconfig.lib.json"
    },
    {
      "path": "../libs/rfc-9110-rules/tsconfig.lib.json"
    },
    {
      "path": "../plugins/openapi/tsconfig.lib.json"
    },
    {
      "path": "../plugins/http-linter/tsconfig.lib.json"
    },
    {
      "path": "../plugins/format-validator/tsconfig.lib.json"
    },
    {
      "path": "../plugins/cli-reporter/tsconfig.lib.json"
    },
    {
      "path": "../libs/cli-common/tsconfig.lib.json"
    }
  ]
}
