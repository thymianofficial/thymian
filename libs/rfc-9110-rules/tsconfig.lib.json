{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"],
  "references": [
    {
      "path": "../../shared/test-utils/tsconfig.lib.json"
    },
    {
      "path": "../../core/tsconfig.lib.json"
    },
    {
      "path": "../http-status-codes/tsconfig.lib.json"
    },
    {
      "path": "../http-testing/tsconfig.lib.json"
    },
    {
      "path": "../../plugins/http-linter/tsconfig.lib.json"
    }
  ]
}
