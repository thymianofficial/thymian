---
/**
 * EnterpriseConsulting – service showcase for the enterprise page.
 *
 * Follows the same visual patterns as the home-page components
 * (CliShowcase, PluginEcosystem, RulesDriftPrevention):
 *   - Section header (h2 + subtitle)
 *   - Service card grid (2-col desktop, 1-col mobile)
 *   - Highlighted card for AI workflow
 *   - CTA callout with email button
 *   - Scroll-reveal animations via IntersectionObserver
 *   - Full dark-mode support
 */

// ── Data ────────────────────────────────────────────────────────────────
interface Service {
  id: string;
  icon: string;
  title: string;
  description: string;
  highlight?: boolean;
}

const services: Service[] = [
  {
    id: 'auditing',
    icon: '🔍',
    title: 'HTTP Conformance Auditing',
    description:
      'Your APIs may pass functional tests and still violate HTTP semantics in ways that cause real outages. We perform deep conformance audits using Thymian\u2019s rule engine \u2014 the same RFC 9110 rules we authored \u2014 to uncover protocol violations in your specifications, implementations, and live production traffic. You receive a detailed report mapping every violation to its RFC source, its real-world risk, and a concrete remediation path.',
  },
  {
    id: 'governance',
    icon: '📋',
    title: 'API Governance & Organizational Standards',
    description:
      'Enforce consistent API quality across every team without slowing anyone down. We help you design and package shareable rule sets as npm modules \u2014 your own @your-org/api-standards \u2014 that validate at design time, test before merge, and monitor in production. One rule definition, enforced across Thymian\u2019s three contexts (lint, test, analyze). Zero drift.',
  },
  {
    id: 'design',
    icon: '📐',
    title: 'API Design Strategy',
    description:
      'Good API design starts before the first line of code. We work with your architects to establish design patterns that are conformant by construction \u2014 versioning strategies, error response structures, content negotiation, and caching policies aligned with HTTP semantics from day one. Using Thymian\u2019s static analysis, we validate your OpenAPI specifications against your organizational standards before implementation begins.',
  },
  {
    id: 'production',
    icon: '🌐',
    title: 'Production Traffic Analysis',
    description:
      'Your specification says one thing. Your implementation does another. And your infrastructure changes both. Using Thymian\u2019s analyze capability, we audit recorded HTTP traffic from your production environment to uncover how proxies, CDNs, and load balancers alter HTTP semantics in ways your tests never see. This is where the hardest-to-find conformance issues live \u2014 and where most tools stop looking.',
  },
  {
    id: 'ai',
    icon: '🤖',
    title: 'AI-Assisted API Development',
    description:
      'AI agents generate code fast \u2014 but they generate incorrect HTTP semantics just as fast. Thymian closes that gap. Its CLI is built for agentic workflows: structured JSON output, deterministic feedback loops, rich error context with rule IDs and RFC references, and a non-interactive mode designed for automated generate-validate-fix cycles. We help you integrate Thymian as the conformance guardrail in your AI-assisted development pipelines \u2014 whether your teams use GitHub Copilot, Cursor, or custom AI agents. The result: your AI tools ship code that is correct by construction, not by luck.',
    highlight: true,
  },
  {
    id: 'lifecycle',
    icon: '🔄',
    title: 'Lifecycle & CI/CD Integration',
    description:
      'Integrate Thymian across your entire development lifecycle: design-time validation in your IDE, automated conformance checks in pull requests, and production traffic analysis in your monitoring stack. We configure Thymian\u2019s CLI for non-interactive CI/CD execution (GitHub Actions, Jenkins, GitLab CI), set up structured output for AI-assisted remediation workflows, and establish the feedback loops that keep your APIs conformant at every stage.',
  },
  {
    id: 'plugins',
    icon: '🔧',
    title: 'Custom Plugin & Rule Development',
    description:
      'Thymian\u2019s plugin architecture is designed for extension \u2014 and nobody knows it better than the team who built it. We design and develop custom plugins for your proprietary protocols, internal APIs, and domain-specific validation requirements. Need validation logic in a language other than TypeScript? We build remote plugins using Thymian\u2019s WebSocket-based system to integrate with any stack.',
  },
  {
    id: 'enablement',
    icon: '🎓',
    title: 'Team Enablement',
    description:
      'We don\u2019t just configure tools \u2014 we transfer knowledge. Our hands-on workshops cover HTTP semantics through the lens of real RFC requirements, custom rule authoring with Thymian\u2019s fluent rule API, plugin development, and production traffic analysis techniques. Your team leaves with the skills to maintain and extend your API governance independently. Includes custom training materials tailored to your architecture.',
  },
];
---

<!-- Enable scroll-reveal animations only when IntersectionObserver is available -->
<script is:inline>
  'IntersectionObserver' in window && (document.documentElement.dataset.animations = '');
</script>

<section class="ec-section not-content" aria-labelledby="ec-heading" id="ec-services">
  <!-- ═════════ Section header ═════════ -->
  <div class="text-center mb-8 lg:mb-12">
    <h2
      id="ec-heading"
      class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3"
    >
      Consulting Services
    </h2>
    <p
      class="text-base lg:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto"
    >
      Hands-on guidance from the engineers who built Thymian &mdash; tailored to
      your architecture, your stack, and your standards.
    </p>
  </div>

  <!-- ═════════ Service cards grid ═════════ -->
  <div class="ec-services">
    {
      services.map((svc, i) => (
        <div
          class={`ec-card ${svc.highlight ? 'ec-card--highlight' : ''}`}
          data-animate="service"
          data-delay={i * 80}
        >
          <div class="ec-card-accent" aria-hidden="true" />
          <div class="ec-card-body">
            <div class="ec-card-header">
              <span class="ec-card-icon-wrap">
                <span class="ec-card-icon" aria-hidden="true">
                  {svc.icon}
                </span>
              </span>
              <h3 class="ec-card-title">{svc.title}</h3>
            </div>
            <p class="ec-card-desc">{svc.description}</p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- ═════════ CTA callout ═════════ -->
  <div class="ec-cta" data-animate="cta">
    <div class="ec-cta-inner">
      <div class="ec-cta-icon-wrap" aria-hidden="true">
        <svg class="ec-cta-icon" viewBox="0 0 24 24" fill="none">
          <path
            d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <circle
            cx="9"
            cy="7"
            r="4"
            stroke="currentColor"
            stroke-width="1.5"></circle>
          <path
            d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
      <div class="ec-cta-content">
        <h3 class="ec-cta-title">Work With the Creators of Thymian</h3>
        <p class="ec-cta-desc">
          Every engagement is led by the engineers who designed and built
          Thymian&rsquo;s core architecture, rule engine, and plugin system. This
          isn&rsquo;t outsourced consulting &mdash; it&rsquo;s direct access to
          the team that understands HTTP conformance at the RFC level. We start
          with a discovery call to understand your architecture, your challenges,
          and your goals.
        </p>
        <a
          href="mailto:support@thymian.com?subject=Enterprise%20Consultation"
          class="ec-cta-button"
        >
          <svg
            class="ec-cta-button-icon"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
            ></path>
            <path
              d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
            ></path>
          </svg>
          Schedule a Consultation
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ Styles ═══════════════ -->
<style>
  /* ── Section wrapper ───────────────────────────────────────── */
  .ec-section {
    --ec-radius: 0.75rem;
    max-width: 80rem;
    margin-inline: auto;
    padding: 2rem 1rem;
  }
  @media (min-width: 640px) {
    .ec-section {
      padding: 2.5rem 1.5rem;
    }
  }
  @media (min-width: 1024px) {
    .ec-section {
      padding: 3rem 2rem;
    }
  }

  /* ── Service cards grid ────────────────────────────────────── */
  .ec-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 768px) {
    .ec-services {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  /* ── Card base ─────────────────────────────────────────────── */
  .ec-card {
    position: relative;
    border-radius: var(--ec-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
    opacity: 1;
  }
  :global(html[data-animations]) .ec-card {
    opacity: 0;
  }
  :global(html[data-animations]) .ec-card.revealed {
    animation: ecFadeSlideUp 0.5s ease-out forwards;
  }
  :global([data-theme='dark']) .ec-card {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }
  .ec-card:hover {
    border-color: var(--color-accent-300);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06);
  }
  :global([data-theme='dark']) .ec-card:hover {
    border-color: var(--color-accent-700);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
  }

  /* Gradient top accent bar */
  .ec-card-accent {
    height: 3px;
    background: var(--gradient-brand);
  }

  /* Highlighted card (AI workflow) */
  .ec-card--highlight {
    border-color: var(--color-accent-200);
    background: var(--color-accent-50);
  }
  :global([data-theme='dark']) .ec-card--highlight {
    border-color: var(--color-accent-800);
    background: var(--color-accent-950);
  }
  .ec-card--highlight .ec-card-accent {
    height: 4px;
  }
  .ec-card--highlight:hover {
    border-color: var(--color-accent-400);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme='dark']) .ec-card--highlight:hover {
    border-color: var(--color-accent-600);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
  }

  /* Card body */
  .ec-card-body {
    padding: 1.25rem 1.35rem 1.35rem;
  }

  /* Card header (icon + title) */
  .ec-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .ec-card-icon-wrap {
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-gray-200);
    flex-shrink: 0;
  }
  :global([data-theme='dark']) .ec-card-icon-wrap {
    background: var(--color-gray-800);
  }
  .ec-card--highlight .ec-card-icon-wrap {
    background: var(--color-accent-200);
  }
  :global([data-theme='dark']) .ec-card--highlight .ec-card-icon-wrap {
    background: var(--color-accent-800);
  }

  .ec-card-icon {
    font-size: 1.15rem;
    line-height: 1;
  }

  .ec-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0;
    line-height: 1.3;
  }
  :global([data-theme='dark']) .ec-card-title {
    color: var(--color-gray-100);
  }

  .ec-card-desc {
    font-size: 0.82rem;
    color: var(--color-gray-600);
    line-height: 1.6;
    margin: 0;
  }
  :global([data-theme='dark']) .ec-card-desc {
    color: var(--color-gray-400);
  }

  /* ── CTA callout ───────────────────────────────────────────── */
  .ec-cta {
    max-width: 52rem;
    margin: 0 auto;
    opacity: 1;
  }
  :global(html[data-animations]) .ec-cta {
    opacity: 0;
  }
  :global(html[data-animations]) .ec-cta.revealed {
    animation: ecFadeSlideUp 0.5s ease-out forwards;
  }

  .ec-cta-inner {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.5rem 1.75rem;
    border-radius: var(--ec-radius);
    border: 1px solid var(--color-accent-200);
    background: linear-gradient(
      135deg,
      var(--color-accent-50) 0%,
      var(--color-accent-alt-50) 100%
    );
  }
  :global([data-theme='dark']) .ec-cta-inner {
    border-color: var(--color-accent-800);
    background: linear-gradient(
      135deg,
      var(--color-accent-950) 0%,
      var(--color-accent-alt-950) 100%
    );
  }

  .ec-cta-icon-wrap {
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--color-accent-100);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global([data-theme='dark']) .ec-cta-icon-wrap {
    background: var(--color-accent-900);
  }

  .ec-cta-icon {
    width: 1.4rem;
    height: 1.4rem;
    color: var(--color-accent-600);
  }
  :global([data-theme='dark']) .ec-cta-icon {
    color: var(--color-accent-400);
  }

  .ec-cta-content {
    flex: 1;
    min-width: 0;
  }

  .ec-cta-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.45rem;
  }
  :global([data-theme='dark']) .ec-cta-title {
    color: var(--color-gray-100);
  }

  .ec-cta-desc {
    font-size: 0.82rem;
    color: var(--color-gray-600);
    line-height: 1.6;
    margin: 0 0 1rem;
  }
  :global([data-theme='dark']) .ec-cta-desc {
    color: var(--color-gray-400);
  }

  .ec-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 700;
    background: var(--color-accent-600);
    color: #fff;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
  }
  .ec-cta-button:hover {
    background: var(--color-accent-500);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    transform: translateY(-1px);
  }
  :global([data-theme='dark']) .ec-cta-button {
    background: var(--color-accent-500);
  }
  :global([data-theme='dark']) .ec-cta-button:hover {
    background: var(--color-accent-400);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }
  .ec-cta-button:focus-visible {
    outline: 2px solid var(--color-accent-400);
    outline-offset: 2px;
  }

  .ec-cta-button-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* ── Responsive: hide CTA icon on very small screens ───────── */
  @media (max-width: 479px) {
    .ec-cta-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
      padding: 1.25rem 1.25rem;
    }
    .ec-cta-icon-wrap {
      align-self: flex-start;
    }
  }

  /* ── Animations ────────────────────────────────────────────── */
  @keyframes ecFadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ec-card,
    .ec-cta {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<!-- ═══════════════ Scroll-triggered reveal ═══════════════ -->
<script>
  function initEnterpriseConsulting() {
    const section = document.querySelector('.ec-section');
    if (!section) return;

    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    const serviceCards =
      section.querySelectorAll<HTMLElement>('.ec-card');
    const cta = section.querySelector<HTMLElement>('.ec-cta');

    if (prefersReduced) {
      serviceCards.forEach((c) => c.classList.add('revealed'));
      cta?.classList.add('revealed');
      return;
    }

    if (!('IntersectionObserver' in window)) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          // Reveal service cards with stagger
          serviceCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${delay}ms`;
            card.classList.add('revealed');
          });

          // Reveal CTA last
          if (cta) {
            cta.style.animationDelay = `${serviceCards.length * 80 + 200}ms`;
            cta.classList.add('revealed');
          }

          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.1 },
    );

    observer.observe(section);
  }

  initEnterpriseConsulting();
  document.addEventListener('astro:after-swap', initEnterpriseConsulting);
</script>
