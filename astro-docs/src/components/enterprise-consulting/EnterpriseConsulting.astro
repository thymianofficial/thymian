---
/**
 * EnterpriseConsulting – service showcase for the enterprise page.
 *
 * Layout:
 *   - Section header (h2 + subtitle)
 *   - Service card grid (2-col desktop, 1-col mobile)
 *   - Highlighted card for AI workflow
 *   - CTA callout via shared CtaCallout component
 *   - Scroll-reveal animations via shared utility
 */

import CtaCallout from '../enterprise-shared/CtaCallout.astro';

// ── Data ────────────────────────────────────────────────────────────────
interface Service {
  id: string;
  icon: string;
  title: string;
  description: string;
  highlight?: boolean;
}

const services: Service[] = [
  {
    id: 'auditing',
    icon: '🔍',
    title: 'HTTP Conformance Auditing',
    description:
      'Your APIs may pass functional tests and still violate HTTP semantics in ways that cause real outages. We perform deep conformance audits using Thymian\u2019s rule engine \u2014 the same RFC 9110 rules we authored \u2014 to uncover protocol violations in your specifications, implementations, and live production traffic. You receive a detailed report mapping every violation to its RFC source, its real-world risk, and a concrete remediation path.',
  },
  {
    id: 'governance',
    icon: '📋',
    title: 'API Governance & Organizational Standards',
    description:
      'Enforce consistent API quality across every team without slowing anyone down. We help you design and package shareable rule sets as npm modules \u2014 your own @your-org/api-standards \u2014 that validate at design time, test before merge, and monitor in production. One rule definition, enforced across Thymian\u2019s three contexts (lint, test, analyze). Zero drift.',
  },
  {
    id: 'design',
    icon: '📐',
    title: 'API Design Strategy',
    description:
      'Good API design starts before the first line of code. We work with your architects to establish design patterns that are conformant by construction \u2014 versioning strategies, error response structures, content negotiation, and caching policies aligned with HTTP semantics from day one. Using Thymian\u2019s static analysis, we validate your OpenAPI specifications against your organizational standards before implementation begins.',
  },
  {
    id: 'production',
    icon: '🌐',
    title: 'Production Traffic Analysis',
    description:
      'Your specification says one thing. Your implementation does another. And your infrastructure changes both. Using Thymian\u2019s analyze capability, we audit recorded HTTP traffic from your production environment to uncover how proxies, CDNs, and load balancers alter HTTP semantics in ways your tests never see. This is where the hardest-to-find conformance issues live \u2014 and where most tools stop looking.',
  },
  {
    id: 'ai',
    icon: '🤖',
    title: 'AI-Assisted API Development',
    description:
      'AI agents generate code fast \u2014 but they generate incorrect HTTP semantics just as fast. Thymian closes that gap. Its CLI is built for agentic workflows: structured JSON output, deterministic feedback loops, rich error context with rule IDs and RFC references, and a non-interactive mode designed for automated generate-validate-fix cycles. We help you integrate Thymian as the conformance guardrail in your AI-assisted development pipelines \u2014 whether your teams use GitHub Copilot, Cursor, or custom AI agents. The result: your AI tools ship code that is correct by construction, not by luck.',
    highlight: true,
  },
  {
    id: 'lifecycle',
    icon: '🔄',
    title: 'Lifecycle & CI/CD Integration',
    description:
      'Integrate Thymian across your entire development lifecycle: design-time validation in your IDE, automated conformance checks in pull requests, and production traffic analysis in your monitoring stack. We configure Thymian\u2019s CLI for non-interactive CI/CD execution (GitHub Actions, Jenkins, GitLab CI), set up structured output for AI-assisted remediation workflows, and establish the feedback loops that keep your APIs conformant at every stage.',
  },
  {
    id: 'plugins',
    icon: '🔧',
    title: 'Custom Plugin & Rule Development',
    description:
      'Thymian\u2019s plugin architecture is designed for extension \u2014 and nobody knows it better than the team who built it. We design and develop custom plugins for your proprietary protocols, internal APIs, and domain-specific validation requirements. Need validation logic in a language other than TypeScript? We build remote plugins using Thymian\u2019s WebSocket-based system to integrate with any stack.',
  },
  {
    id: 'enablement',
    icon: '🎓',
    title: 'Team Enablement',
    description:
      'We don\u2019t just configure tools \u2014 we transfer knowledge. Our hands-on workshops cover HTTP semantics through the lens of real RFC requirements, custom rule authoring with Thymian\u2019s fluent rule API, plugin development, and production traffic analysis techniques. Your team leaves with the skills to maintain and extend your API governance independently. Includes custom training materials tailored to your architecture.',
  },
];
---

<section class="ec-section not-content" aria-labelledby="ec-heading" id="consulting-services">
  <!-- ═════════ Section header ═════════ -->
  <header class="ec-header">
    <h2 id="ec-heading" class="ec-heading">Consulting Services</h2>
    <p class="ec-subtitle">
      Hands-on guidance from the engineers who built Thymian &mdash; tailored to
      your architecture, your stack, and your standards.
    </p>
  </header>

  <!-- ═════════ Service cards grid ═════════ -->
  <div class="ec-services">
    {
      services.map((svc, i) => (
        <div
          class={`ec-card ${svc.highlight ? 'ec-card--highlight' : ''}`}
          data-animate="service"
          data-delay={i * 80}
        >
          <div class="ec-card-accent" aria-hidden="true" />
          <div class="ec-card-body">
            <div class="ec-card-header">
              <span class="ec-card-icon-wrap">
                <span class="ec-card-icon" aria-hidden="true">
                  {svc.icon}
                </span>
              </span>
              <h3 class="ec-card-title">{svc.title}</h3>
            </div>
            <p class="ec-card-desc">{svc.description}</p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- ═════════ CTA callout ═════════ -->
  <CtaCallout title="Not Sure Where to Start?">
    <p class="ec-cta-desc">
      Most engagements begin with a short call. Walk us through your
      API landscape and pain points &mdash; we&rsquo;ll tell you
      which services make sense and which ones you can skip.
      No pitch deck, no commitment.
    </p>
  </CtaCallout>
</section>

<!-- ═══════════════ Styles ═══════════════ -->
<style>
  @import '../../styles/enterprise-shared.css';

  /* ── Section wrapper ───────────────────────────────────────── */
  .ec-section {
    max-width: var(--ep-section-max-width);
    margin-inline: auto;
    padding: var(--ep-section-gap) var(--ep-section-padding-x);
  }

  /* ── Header ────────────────────────────────────────────────── */
  .ec-header {
    text-align: center;
    margin-bottom: var(--ep-header-mb);
  }
  .ec-heading {
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.75rem;
  }
  :global([data-theme='dark']) .ec-heading {
    color: var(--color-gray-100);
  }
  .ec-subtitle {
    font-size: clamp(0.95rem, 1.5vw, 1.125rem);
    color: var(--color-gray-500);
    max-width: 42rem;
    margin: 0 auto;
  }
  :global([data-theme='dark']) .ec-subtitle {
    color: var(--color-gray-400);
  }

  /* ── Service cards grid ────────────────────────────────────── */
  .ec-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ep-grid-gap);
    margin-bottom: var(--ep-grid-mb);
  }
  @media (min-width: 768px) {
    .ec-services {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Card base ─────────────────────────────────────────────── */
  .ec-card {
    position: relative;
    border-radius: var(--ep-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
    opacity: 1;
  }
  :global(html[data-animations]) .ec-card {
    opacity: 0;
  }
  :global(html[data-animations]) .ec-card.revealed {
    animation: enterpriseFadeSlideUp 0.5s ease-out forwards;
  }
  :global([data-theme='dark']) .ec-card {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }
  .ec-card:hover {
    border-color: var(--color-accent-300);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06);
  }
  :global([data-theme='dark']) .ec-card:hover {
    border-color: var(--color-accent-700);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
  }

  /* Gradient top accent bar */
  .ec-card-accent {
    height: 3px;
    background: var(--gradient-brand);
  }

  /* Highlighted card (AI workflow) */
  .ec-card--highlight {
    border-color: var(--color-accent-200);
    background: var(--color-accent-50);
  }
  :global([data-theme='dark']) .ec-card--highlight {
    border-color: var(--color-accent-800);
    background: var(--color-accent-950);
  }
  .ec-card--highlight .ec-card-accent {
    height: 4px;
  }
  .ec-card--highlight:hover {
    border-color: var(--color-accent-400);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme='dark']) .ec-card--highlight:hover {
    border-color: var(--color-accent-600);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
  }

  /* Card body */
  .ec-card-body {
    padding: var(--ep-card-padding) 1.35rem 1.35rem;
  }

  /* Card header (icon + title) */
  .ec-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .ec-card-icon-wrap {
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-gray-200);
    flex-shrink: 0;
  }
  :global([data-theme='dark']) .ec-card-icon-wrap {
    background: var(--color-gray-800);
  }
  .ec-card--highlight .ec-card-icon-wrap {
    background: var(--color-accent-200);
  }
  :global([data-theme='dark']) .ec-card--highlight .ec-card-icon-wrap {
    background: var(--color-accent-800);
  }

  .ec-card-icon {
    font-size: 1.15rem;
    line-height: 1;
  }

  .ec-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0;
    line-height: 1.3;
  }
  :global([data-theme='dark']) .ec-card-title {
    color: var(--color-gray-100);
  }

  .ec-card-desc {
    font-size: 0.82rem;
    color: var(--color-gray-600);
    line-height: 1.6;
    margin: 0;
  }
  :global([data-theme='dark']) .ec-card-desc {
    color: var(--color-gray-400);
  }

  /* ── CTA desc (inside CtaCallout slot) ─────────────────────── */
  .ec-cta-desc {
    font-size: 0.82rem;
    color: var(--color-gray-600);
    line-height: 1.6;
    margin: 0 0 1rem;
  }
  :global([data-theme='dark']) .ec-cta-desc {
    color: var(--color-gray-400);
  }

  /* ── Reduced motion ────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .ec-card {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<!-- ═══════════════ Scroll-triggered reveal ═══════════════ -->
<script>
  import { initScrollReveal } from '../enterprise-shared/scroll-reveal';

  function init() {
    initScrollReveal('.ec-section', [
      { selector: '.ec-card', baseDelay: 0 },
      { selector: '.ent-cta', baseDelay: 700 },
    ]);
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
