---
/**
 * EnterpriseProblem – visual framing section for the enterprise page.
 *
 * Establishes the problem space that enterprise consulting solves:
 * silent infrastructure issues, API drift, and invisible compliance gaps.
 *
 * Layout:
 *   1. Centered header (h2 + hook subtitle)
 *   2. 3 pain-point cards (3-col grid, compact)
 *   3. 2 incident cards (security-alert style, side-by-side)
 *   4. Authority callout (gradient background)
 */

// ── Data ────────────────────────────────────────────────────────────────
interface PainPoint {
  icon: string;
  title: string;
  description: string;
}

interface Incident {
  icon: string;
  title: string;
  severity: 'Critical' | 'High';
  severityColor: 'red' | 'orange';
  rfc: string;
  rfcSection: string;
  description: string;
  impact: string;
}

const painPoints: PainPoint[] = [
  {
    icon: '🌐',
    title: 'Silent Infrastructure Changes',
    description:
      'CDNs rewrite Cache-Control headers. Load balancers strip Content-Encoding. Reverse proxies inject Via headers that leak internal hostnames. None of these trigger a test failure.',
  },
  {
    icon: '📡',
    title: 'API Drift at Scale',
    description:
      'Specifications drift from implementations across dozens of teams and hundreds of endpoints. Without protocol-level enforcement, every service becomes its own dialect of HTTP.',
  },
  {
    icon: '🕳️',
    title: 'Invisible Compliance Gaps',
    description:
      'Functional tests pass. Integration tests pass. But HTTP semantics violations — missing headers, wrong status codes, malformed content negotiation — lurk undetected until they cause incidents.',
  },
];

const incidents: Incident[] = [
  {
    icon: '🔓',
    title: 'Request Smuggling via Content-Length',
    severity: 'Critical',
    severityColor: 'red',
    rfc: 'RFC 9110',
    rfcSection: '§8.6',
    description:
      'A Content-Length header that doesn\'t match the actual body size lets attackers inject requests into other users\' connections — the same class of vulnerability that has breached major cloud providers.',
    impact: 'Data exfiltration, authentication bypass, cache poisoning',
  },
  {
    icon: '🔀',
    title: 'Cache Poisoning via Missing Vary',
    severity: 'High',
    severityColor: 'orange',
    rfc: 'RFC 9110',
    rfcSection: '§12.5.5',
    description:
      'A missing Vary header on a cached response means one user\'s authenticated content gets served to another — turning your caching layer into a data leak.',
    impact: 'Data leaks, session hijacking, compliance violations',
  },
];
---

<!-- Enable scroll-reveal animations only when IntersectionObserver is available -->
<script is:inline>
  'IntersectionObserver' in window && (document.documentElement.dataset.animations = '');
</script>

<section class="ep-section not-content" aria-labelledby="ep-heading">
  <!-- ═════════ Header ═════════ -->
  <div class="text-center mb-8 lg:mb-12">
    <h2
      id="ep-heading"
      class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3"
    >
      The Problem at Scale
    </h2>
    <p
      class="text-base lg:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto"
    >
      Most API issues don't surface in development. They surface in production
      — when it's already an incident, not a bug.
    </p>
  </div>

  <!-- ═════════ Pain point cards (3-col) ═════════ -->
  <div class="ep-pain-points">
    {
      painPoints.map((p, i) => (
        <div
          class="ep-pain-card"
          data-animate="pain"
          data-delay={i * 100}
        >
          <span class="ep-pain-icon" aria-hidden="true">{p.icon}</span>
          <h3 class="ep-pain-title">{p.title}</h3>
          <p class="ep-pain-desc">{p.description}</p>
        </div>
      ))
    }
  </div>

  <!-- ═════════ Incident cards (2-col, security-alert style) ═════════ -->
  <div class="text-center mb-6 mt-10 lg:mt-14">
    <h3
      class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2"
    >
      Real Vulnerabilities Thymian Catches
    </h3>
    <p class="text-sm text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
      Thymian ships with an extensive RFC 9110 rule set covering dozens of
      protocol requirements. Here are two examples of violations it catches
      — each one responsible for real-world breaches.
    </p>
  </div>

  <div class="ep-incidents">
    {
      incidents.map((inc, i) => (
        <div
          class={`ep-incident-card ep-incident-card--${inc.severityColor}`}
          data-animate="incident"
          data-delay={i * 150}
        >
          <div class="ep-incident-header">
            <span class="ep-incident-icon" aria-hidden="true">{inc.icon}</span>
            <div class="ep-incident-meta">
              <h4 class="ep-incident-title">{inc.title}</h4>
              <span class="ep-incident-rfc">{inc.rfc} {inc.rfcSection}</span>
            </div>
            <span class={`ep-severity ep-severity--${inc.severityColor}`}>
              {inc.severityColor === 'red' ? '🔴' : '🟠'} {inc.severity}
            </span>
          </div>
          <div class="ep-incident-body">
            <p class="ep-incident-desc">{inc.description}</p>
            <div class="ep-incident-impact">
              <span class="ep-impact-label">Impact</span>
              <span class="ep-impact-value">{inc.impact}</span>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- ═════════ "And more" indicator ═════════ -->
  <div class="ep-more" data-animate="more">
    <span class="ep-more-text">
      Plus: Server header fingerprinting, Via header information leaks, userinfo
      in URIs, content negotiation errors, and dozens more RFC 9110 violations
    </span>
  </div>

  <!-- ═════════ Authority callout ═════════ -->
  <div class="ep-authority" data-animate="authority">
    <div class="ep-authority-inner">
      <div class="ep-authority-icon-wrap" aria-hidden="true">
        <svg class="ep-authority-icon" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 2L2 7l10 5 10-5-10-5Z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <path
            d="M2 17l10 5 10-5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <path
            d="M2 12l10 5 10-5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </div>
      <div class="ep-authority-content">
        <h3 class="ep-authority-title">We Wrote the Rules — Literally</h3>
        <p class="ep-authority-desc">
          We built the RFC 9110 rule set from scratch, mapped every
          <strong>MUST</strong>, <strong>SHOULD</strong>, and <strong>MAY</strong>
          to actionable validation, and designed a system that enforces them
          identically at design time, during testing, and in production. That
          depth of understanding is what we bring to your organization.
        </p>
      </div>
    </div>
  </div>

  <!-- ═════════ Contact CTA ═════════ -->
  <div class="ep-contact" data-animate="contact">
    <p class="ep-contact-text">
      Want to find out what Thymian would flag in your infrastructure?
    </p>
    <a
      href="mailto:support@thymian.com?subject=Enterprise%20Consultation"
      class="ep-contact-button"
    >
      <svg
        class="ep-contact-button-icon"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
        />
        <path
          d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
        />
      </svg>
      Get in Touch
    </a>
  </div>
</section>

<!-- ═══════════════ Styles ═══════════════ -->
<style>
  /* ── Section wrapper ───────────────────────────────────────── */
  .ep-section {
    --ep-radius: 0.75rem;
    max-width: 80rem;
    margin-inline: auto;
    padding: 2rem 1rem;
  }
  @media (min-width: 640px) {
    .ep-section { padding: 2.5rem 1.5rem; }
  }
  @media (min-width: 1024px) {
    .ep-section { padding: 3rem 2rem; }
  }

  /* ── Pain point cards ──────────────────────────────────────── */
  .ep-pain-points {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .ep-pain-points { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .ep-pain-points { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  }

  .ep-pain-card {
    padding: 1.25rem 1.15rem;
    border-radius: var(--ep-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    transition: border-color 0.2s, box-shadow 0.2s;
    opacity: 1;
  }
  :global(html[data-animations]) .ep-pain-card {
    opacity: 0;
  }
  :global(html[data-animations]) .ep-pain-card.revealed {
    animation: epFadeSlideUp 0.5s ease-out forwards;
  }
  :global([data-theme='dark']) .ep-pain-card {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }
  .ep-pain-card:hover {
    border-color: var(--color-accent-300);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }
  :global([data-theme='dark']) .ep-pain-card:hover {
    border-color: var(--color-accent-700);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .ep-pain-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.65rem;
    line-height: 1;
  }
  .ep-pain-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.35rem;
  }
  :global([data-theme='dark']) .ep-pain-title {
    color: var(--color-gray-100);
  }
  .ep-pain-desc {
    font-size: 0.8rem;
    color: var(--color-gray-600);
    line-height: 1.55;
    margin: 0;
  }
  :global([data-theme='dark']) .ep-pain-desc {
    color: var(--color-gray-400);
  }

  /* ── Incident cards ────────────────────────────────────────── */
