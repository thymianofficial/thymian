  .ep-authority-inner {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
    border-radius: var(--ep-radius);
    border: 1px solid var(--color-accent-200);
    background: linear-gradient(
