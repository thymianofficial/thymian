    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global([data-theme='dark']) .ep-authority-icon-wrap {
    background: var(--color-accent-900);
  }
  .ep-authority-icon {
    width: 1.3rem;
    height: 1.3rem;
    color: var(--color-accent-600);
  }
  :global([data-theme='dark']) .ep-authority-icon {
    color: var(--color-accent-400);
  }
  .ep-authority-content {
    flex: 1;
    min-width: 0;
  }
  .ep-authority-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.35rem;
  }
  :global([data-theme='dark']) .ep-authority-title {
    color: var(--color-gray-100);
  }
  .ep-authority-desc {
    font-size: 0.8rem;
    color: var(--color-gray-600);
    line-height: 1.55;
    margin: 0;
  }
  :global([data-theme='dark']) .ep-authority-desc {
    color: var(--color-gray-400);
  }
  .ep-authority-desc strong {
    color: var(--color-accent-700);
    font-weight: 700;
  }
  :global([data-theme='dark']) .ep-authority-desc strong {
    color: var(--color-accent-300);
  }

  /* ── Contact CTA ─────────────────────────────────────────── */
  .ep-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    text-align: center;
    margin-top: 2.5rem;
    padding: 2rem 1.5rem;
    border-radius: var(--ep-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-50);
    opacity: 1;
  }
  :global(html[data-animations]) .ep-contact {
    opacity: 0;
  }
  :global(html[data-animations]) .ep-contact.revealed {
    animation: epFadeSlideUp 0.5s ease-out forwards;
  }
  :global([data-theme='dark']) .ep-contact {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }
  .ep-contact-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-gray-700);
    margin: 0;
  }
  :global([data-theme='dark']) .ep-contact-text {
    color: var(--color-gray-300);
  }
  .ep-contact-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    border-radius: 9999px;
    font-size: 0.88rem;
    font-weight: 700;
    background: var(--color-accent-600);
    color: #fff;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
  }
  .ep-contact-button:hover {
    background: var(--color-accent-500);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    transform: translateY(-1px);
  }
  :global([data-theme='dark']) .ep-contact-button {
    background: var(--color-accent-500);
  }
  :global([data-theme='dark']) .ep-contact-button:hover {
    background: var(--color-accent-400);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }
  .ep-contact-button:focus-visible {
    outline: 2px solid var(--color-accent-400);
    outline-offset: 2px;
  }
  .ep-contact-button-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* ── Animations ─────────────────────────────────────────────── */
  @keyframes epFadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ep-pain-card,
    .ep-incident-card,
    .ep-more,
    .ep-authority,
    .ep-contact {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<!-- ═══════════════ Scroll-triggered reveal ═══════════════ -->
<script>
  function initEnterpriseProblem() {
    const section = document.querySelector('.ep-section');
    if (!section) return;

    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    const painCards = section.querySelectorAll<HTMLElement>('.ep-pain-card');
    const incidentCards = section.querySelectorAll<HTMLElement>('.ep-incident-card');
    const more = section.querySelector<HTMLElement>('.ep-more');
    const authority = section.querySelector<HTMLElement>('.ep-authority');
    const contact = section.querySelector<HTMLElement>('.ep-contact');

    if (prefersReduced) {
      painCards.forEach((c) => c.classList.add('revealed'));
      incidentCards.forEach((c) => c.classList.add('revealed'));
      more?.classList.add('revealed');
      authority?.classList.add('revealed');
      contact?.classList.add('revealed');
      return;
    }

    if (!('IntersectionObserver' in window)) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          // 1. Reveal pain point cards with stagger
          painCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${delay}ms`;
            card.classList.add('revealed');
          });

          // 2. Reveal incident cards with stagger
          incidentCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${400 + delay}ms`;
            card.classList.add('revealed');
          });

          // 3. Reveal "and more" indicator
          if (more) {
            more.style.animationDelay = '700ms';
            more.classList.add('revealed');
          }

          // 4. Reveal authority callout
          if (authority) {
            authority.style.animationDelay = '850ms';
            authority.classList.add('revealed');
          }

          // 5. Reveal contact CTA last
          if (contact) {
            contact.style.animationDelay = '1000ms';
            contact.classList.add('revealed');
          }

          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.1 },
    );

    observer.observe(section);
  }

  initEnterpriseProblem();
  document.addEventListener('astro:after-swap', initEnterpriseProblem);
</script>
