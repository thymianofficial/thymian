    opacity: 0;
  }
  :global(html[data-animations]) .ep-incident-card.revealed {
    animation: epFadeSlideUp 0.5s ease-out forwards;
  }
  :global([data-theme='dark']) .ep-incident-card {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }

  /* Severity-colored left border */
  .ep-incident-card--red {
    border-left-color: #ef4444;
  }
  .ep-incident-card--orange {
    border-left-color: #f97316;
  }

  .ep-incident-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme='dark']) .ep-incident-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .ep-incident-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-gray-200);
  }
  :global([data-theme='dark']) .ep-incident-header {
    border-color: var(--color-gray-700);
  }
  .ep-incident-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
  }
  .ep-incident-meta {
    flex: 1;
    min-width: 0;
  }
  .ep-incident-title {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0;
    line-height: 1.3;
  }
  :global([data-theme='dark']) .ep-incident-title {
    color: var(--color-gray-100);
  }
  .ep-incident-rfc {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-gray-500);
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas,
      'Liberation Mono', monospace;
  }

  /* Severity badge */
  .ep-severity {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border-radius: 9999px;
    padding: 0.2rem 0.65rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ep-severity--red {
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
  }
  :global([data-theme='dark']) .ep-severity--red {
    background: rgba(239, 68, 68, 0.12);
    color: #fca5a5;
    border-color: rgba(239, 68, 68, 0.3);
  }
  .ep-severity--orange {
    background: #fff7ed;
    color: #ea580c;
    border: 1px solid #fed7aa;
  }
  :global([data-theme='dark']) .ep-severity--orange {
    background: rgba(249, 115, 22, 0.12);
    color: #fdba74;
    border-color: rgba(249, 115, 22, 0.3);
  }

  .ep-incident-body {
    padding: 0.85rem 1rem;
  }
  .ep-incident-desc {
    font-size: 0.8rem;
    color: var(--color-gray-600);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }
  :global([data-theme='dark']) .ep-incident-desc {
    color: var(--color-gray-400);
  }

  .ep-incident-impact {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding-top: 0.55rem;
    border-top: 1px solid var(--color-gray-200);
  }
  :global([data-theme='dark']) .ep-incident-impact {
    border-color: var(--color-gray-700);
  }
  .ep-impact-label {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-500);
  }
  .ep-impact-value {
    font-size: 0.75rem;
    color: var(--color-gray-700);
    line-height: 1.4;
  }
  :global([data-theme='dark']) .ep-impact-value {
    color: var(--color-gray-300);
  }

  /* ── "And more" indicator ────────────────────────────────────── */
  .ep-more {
    text-align: center;
    margin-bottom: 2.5rem;
    opacity: 1;
  }
  :global(html[data-animations]) .ep-more {
    opacity: 0;
  }
  :global(html[data-animations]) .ep-more.revealed {
    animation: epFadeSlideUp 0.5s ease-out forwards;
  }
  .ep-more-text {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--color-gray-500);
    line-height: 1.5;
    padding: 0.45rem 1rem;
    border-radius: var(--ep-radius);
    border: 1px dashed var(--color-gray-300);
    background: var(--color-gray-50);
  }
  :global([data-theme='dark']) .ep-more-text {
    color: var(--color-gray-400);
    border-color: var(--color-gray-600);
    background: var(--color-gray-900);
  }

  /* ── Authority callout ─────────────────────────────────────── */
  .ep-authority {
    max-width: 52rem;
    margin: 0 auto;
    opacity: 1;
  }
  :global(html[data-animations]) .ep-authority {
    opacity: 0;
  }
  :global(html[data-animations]) .ep-authority.revealed {
    animation: epFadeSlideUp 0.5s ease-out forwards;
