  .ep-incident-card {
    border-radius: var(--ep-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    overflow: hidden;
    border-left: 3px solid transparent;
    transition: box-shadow 0.2s, border-color 0.2s;
