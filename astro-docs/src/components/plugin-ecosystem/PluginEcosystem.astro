  @media (prefers-reduced-motion: reduce) {
    .pe-strength-card,
    .pe-hub-core,
    .pe-hub-spoke,
    .pe-code-card,
    .pe-plugin-card,
    .pe-callout {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<!-- ═══════════════ Scroll-triggered reveal ═══════════════ -->
<script>
  function initPluginEcosystem() {
    const section = document.querySelector('.pe-section');
    if (!section) return;

    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    const strengthCards = section.querySelectorAll<HTMLElement>(
      '.pe-strength-card',
    );
    const hubCore = section.querySelector<HTMLElement>('.pe-hub-core');
    const hubSpokes =
      section.querySelectorAll<HTMLElement>('.pe-hub-spoke');
    const codeCard = section.querySelector<HTMLElement>('.pe-code-card');
    const pluginCards =
      section.querySelectorAll<HTMLElement>('.pe-plugin-card');
    const callout = section.querySelector<HTMLElement>('.pe-callout');

    if (prefersReduced) {
      strengthCards.forEach((c) => c.classList.add('revealed'));
      hubCore?.classList.add('revealed');
      hubSpokes.forEach((s) => s.classList.add('revealed'));
      codeCard?.classList.add('revealed');
      pluginCards.forEach((c) => c.classList.add('revealed'));
      callout?.classList.add('revealed');
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          // 1. Reveal strength cards with stagger
          strengthCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${delay}ms`;
            card.classList.add('revealed');
          });

          // 2. Reveal hub core
          if (hubCore) {
            hubCore.style.animationDelay = '500ms';
            hubCore.classList.add('revealed');
          }

          // 3. Reveal spokes
          hubSpokes.forEach((spoke, i) => {
            spoke.style.animationDelay = `${700 + i * 120}ms`;
            spoke.classList.add('revealed');
          });

          // 4. Reveal code card
          if (codeCard) {
            codeCard.style.animationDelay = '400ms';
            codeCard.classList.add('revealed');
          }

          // 5. Reveal plugin cards with stagger
          pluginCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${600 + delay}ms`;
            card.classList.add('revealed');
          });

          // 6. Reveal callout last
          if (callout) {
            callout.style.animationDelay = '1200ms';
            callout.classList.add('revealed');
          }

          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.1 },
    );

    observer.observe(section);
  }

  initPluginEcosystem();
  document.addEventListener('astro:after-swap', initPluginEcosystem);
</script>


