  /* ── Animations ────────────────────────────────────────────── */
  @keyframes rdpFadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes rdpFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rdp-rule-card,
    .rdp-context-card,
    .rdp-connector-arrow,
    .rdp-shareable {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<!-- ═══════════════ Scroll-triggered reveal ═══════════════ -->
<script>
  function initRulesDriftPrevention() {
    const section = document.querySelector('.rdp-section');
    if (!section) return;

    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    const ruleCard = section.querySelector<HTMLElement>('.rdp-rule-card');
    const contextCards = section.querySelectorAll<HTMLElement>(
      '.rdp-context-card',
    );
    const arrows =
      section.querySelectorAll<HTMLElement>('.rdp-connector-arrow');
    const shareable = section.querySelector<HTMLElement>('.rdp-shareable');

    if (prefersReduced) {
      ruleCard?.classList.add('revealed');
      contextCards.forEach((c) => c.classList.add('revealed'));
      arrows.forEach((a) => a.classList.add('revealed'));
      shareable?.classList.add('revealed');
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          // 1. Reveal rule card
          ruleCard?.classList.add('revealed');

          // 2. Reveal arrows after rule card
          arrows.forEach((arrow, i) => {
            arrow.style.animationDelay = `${400 + i * 100}ms`;
            arrow.classList.add('revealed');
          });

          // 3. Reveal context cards with stagger
          contextCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${600 + delay}ms`;
            card.classList.add('revealed');
          });

          // 4. Reveal shareable callout last
          if (shareable) {
            shareable.style.animationDelay = '1100ms';
            shareable.classList.add('revealed');
          }

          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.1 },
    );

    observer.observe(section);
  }

  initRulesDriftPrevention();
  document.addEventListener('astro:after-swap', initRulesDriftPrevention);
</script>

