---
/**
 * EnterpriseEngagement – "What to Expect" engagement flow section.
 *
 * Shows a simple 3-step process so potential clients understand how
 * engagements work before reaching out.
 *
 * Layout:
 *   - Section header (h2 + subtitle)
 *   - 3 step cards in a horizontal flow with connecting lines
 */

interface Step {
  number: string;
  title: string;
  description: string;
  detail: string;
}

const steps: Step[] = [
  {
    number: '1',
    title: 'Discovery Call',
    description:
      'A 30-minute conversation to understand your API landscape, pain points, and goals. No pitch deck, no commitment.',
    detail: 'Free & no obligation',
  },
  {
    number: '2',
    title: 'Scoped Proposal',
    description:
      'Based on the discovery call, we deliver a written proposal with scope, timeline, deliverables, and pricing — typically within one week.',
    detail: 'Fixed scope & timeline',
  },
  {
    number: '3',
    title: 'Engagement',
    description:
      'We execute the agreed scope, deliver all artifacts, and conduct a handoff session to ensure your team can maintain everything independently.',
    detail: 'Deliverables you own',
  },
];
---

<section class="ee-section not-content" aria-labelledby="ee-heading">
  <header class="ee-header">
    <h2 id="ee-heading" class="ee-heading">What to Expect</h2>
    <p class="ee-subtitle">
      Every engagement follows a straightforward process &mdash; so you know
      exactly what you&rsquo;re getting before you commit.
    </p>
  </header>

  <div class="ee-steps">
    {
      steps.map((step, i) => (
        <div class="ee-step" data-animate="step" data-delay={i * 150}>
          <div class="ee-step-number" aria-hidden="true">{step.number}</div>
          <h3 class="ee-step-title">{step.title}</h3>
          <p class="ee-step-desc">{step.description}</p>
          <span class="ee-step-detail">{step.detail}</span>
          {i < steps.length - 1 && <div class="ee-step-connector" aria-hidden="true" />}
        </div>
      ))
    }
  </div>
</section>

<style is:global>
  @import '../../styles/enterprise-shared.css';
</style>

<style>

  .ee-section {
    max-width: var(--ep-section-max-width);
    margin-inline: auto;
    padding: var(--ep-section-gap) var(--ep-section-padding-x);
  }

  .ee-header {
    text-align: center;
    margin-bottom: var(--ep-header-mb);
  }

  .ee-heading {
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.75rem;
  }
  :global([data-theme='dark']) .ee-heading {
    color: var(--color-gray-100);
  }

  .ee-subtitle {
    font-size: clamp(0.95rem, 1.5vw, 1.125rem);
    color: var(--color-gray-500);
    max-width: 42rem;
    margin: 0 auto;
  }
  :global([data-theme='dark']) .ee-subtitle {
    color: var(--color-gray-400);
  }

  /* ── Steps grid ───────────────────────────────────────────── */
  .ee-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ep-grid-gap);
  }
  @media (min-width: 768px) {
    .ee-steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ee-step {
    position: relative;
    padding: var(--ep-card-padding);
    border-radius: var(--ep-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    text-align: center;
    transition: border-color 0.2s, box-shadow 0.2s;
    opacity: 1;
  }
  :global(html[data-animations]) .ee-step {
    opacity: 0;
  }
  :global(html[data-animations]) .ee-step.revealed {
    animation: enterpriseFadeSlideUp 0.5s ease-out forwards;
  }
  :global([data-theme='dark']) .ee-step {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }
  .ee-step:hover {
    border-color: var(--color-accent-300);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }
  :global([data-theme='dark']) .ee-step:hover {
    border-color: var(--color-accent-700);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .ee-step-number {
    width: 2.5rem;
    height: 2.5rem;
    margin: 0 auto 0.75rem;
    border-radius: 50%;
    background: var(--gradient-brand);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .ee-step-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.5rem;
  }
  :global([data-theme='dark']) .ee-step-title {
    color: var(--color-gray-100);
  }

  .ee-step-desc {
    font-size: 0.82rem;
    color: var(--color-gray-600);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }
  :global([data-theme='dark']) .ee-step-desc {
    color: var(--color-gray-400);
  }

  .ee-step-detail {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent-600);
    background: var(--color-accent-50);
    border: 1px solid var(--color-accent-200);
    border-radius: 9999px;
    padding: 0.2rem 0.7rem;
  }
  :global([data-theme='dark']) .ee-step-detail {
    color: var(--color-accent-400);
    background: var(--color-accent-950);
    border-color: var(--color-accent-800);
  }

  /* Connector arrow (desktop only) */
  .ee-step-connector {
    display: none;
  }
  @media (min-width: 768px) {
    .ee-step-connector {
      display: block;
      position: absolute;
      top: 50%;
      right: -0.85rem;
      transform: translateY(-50%);
      width: 0;
      height: 0;
      border-top: 6px solid transparent;
      border-bottom: 6px solid transparent;
      border-left: 8px solid var(--color-gray-300);
    }
    :global([data-theme='dark']) .ee-step-connector {
      border-left-color: var(--color-gray-600);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ee-step {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<script>
  import { initScrollReveal } from '../enterprise-shared/scroll-reveal';

  function init() {
    initScrollReveal('.ee-section', [
      { selector: '.ee-step', baseDelay: 0 },
    ]);
  }

  init();
  if (!document.documentElement.dataset.enterpriseEngagementAfterSwapListenerRegistered) {
    document.addEventListener('astro:after-swap', init);
    document.documentElement.dataset.enterpriseEngagementAfterSwapListenerRegistered = 'true';
  }
</script>
