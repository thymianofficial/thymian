---
interface DocLink {
  label: string;
  url: string;
}

interface Props {
  links: DocLink[];
  title?: string;
}

const { links, title = 'Documentation Links' } = Astro.props;
---

<div class="doc-links-block">
  <div class="doc-links-title">{title}</div>
  <ul class="doc-links-list">
    {
      links.map((link) => (
        <li class="doc-links-item">
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M5.25 2.625H2.625A.875.875 0 0 0 1.75 3.5v7.875a.875.875 0 0 0 .875.875H10.5a.875.875 0 0 0 .875-.875V8.75M8.75 1.75h3.5v3.5M7 7l5.25-5.25"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.label}
            <span class="doc-links-url">{link.url}</span>
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .doc-links-block {
    border: 1px solid var(--sl-color-gray-5);
    border-left: 3px solid var(--sl-color-accent);
    border-radius: 0.5rem;
    padding: 0.875rem 1rem;
    background: var(--sl-color-gray-6);
  }

  .doc-links-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sl-color-accent);
    margin-bottom: 0.625rem;
  }

  .doc-links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .doc-links-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: var(--sl-color-gray-4);
    font-size: 0.875rem;
  }

  .doc-links-item svg {
    flex-shrink: 0;
    margin-top: 0.1em;
    color: var(--sl-color-accent);
  }

  .doc-links-item a {
    color: var(--sl-color-gray-1, var(--sl-color-white));
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .doc-links-item a:hover {
    color: var(--sl-color-accent);
  }

  .doc-links-url {
    font-size: 0.75rem;
    font-family: monospace;
    color: var(--sl-color-gray-4);
  }

  .doc-links-item a:hover .doc-links-url {
    color: var(--sl-color-accent-low, var(--sl-color-accent));
  }
</style>
