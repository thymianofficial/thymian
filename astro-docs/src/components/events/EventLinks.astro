---
import type { EventCardLink } from './eventMeta';

interface Props {
  links: EventCardLink[];
}

const { links } = Astro.props;
---

{
  links.length > 0 && (
    <ul class="event-links-list">
      {links.map((link) => (
        <li class="event-links-item">
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M5.25 2.625H2.625A.875.875 0 0 0 1.75 3.5v7.875a.875.875 0 0 0 .875.875H10.5a.875.875 0 0 0 .875-.875V8.75M8.75 1.75h3.5v3.5M7 7l5.25-5.25"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .event-links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .event-links-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .event-links-item svg {
    flex-shrink: 0;
    color: var(--sl-color-accent);
  }

  .event-links-item a {
    color: var(--sl-color-accent-high, var(--sl-color-accent));
    font-weight: 600;
    text-decoration: none;
  }

  .event-links-item a:hover {
    text-decoration: underline;
  }
</style>
