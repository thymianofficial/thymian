---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import { resolveLogoAlt } from './eventMeta';

interface Props {
  logo?: ImageMetadata;
  brand: string;
}

const { logo, brand } = Astro.props;

// Decorative monogram for the text-only fallback: first character of the brand,
// uppercased. `aria-hidden` because the visible brand text already carries the
// meaning for assistive tech. Code-point-aware indexing keeps emoji / astral
// first characters (surrogate pairs) intact instead of rendering half a glyph.
const monogram = ([...brand][0] ?? '').toUpperCase();
---

{
  logo ? (
    <div class="event-card-logo">
      <Image src={logo} alt={resolveLogoAlt(brand)} class="event-card-logo-img" />
    </div>
  ) : (
    <div class="event-card-logo event-card-logo--text">
      <span class="event-card-logo-monogram" aria-hidden="true">
        {monogram}
      </span>
      <span class="event-card-logo-brand">{brand}</span>
    </div>
  )
}

<style>
  .event-card-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    height: 2.75rem;
  }

  .event-card-logo-img {
    max-height: 2.75rem;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .event-card-logo--text {
    gap: 0.55rem;
  }

  .event-card-logo-monogram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.5rem;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1;
    color: var(--sl-color-accent-high, var(--sl-color-accent));
    background: color-mix(in srgb, var(--sl-color-accent) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 38%, transparent);
  }

  .event-card-logo-brand {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--sl-color-white);
  }
</style>
