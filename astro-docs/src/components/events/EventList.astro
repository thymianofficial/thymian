---
import type { CollectionEntry } from 'astro:content';

import { classify, type EventDate } from '../../schema/event-date';
import { type ParticipationType } from '../../schema/events';
import EventCard from './EventCard.astro';
import {
  compareUpcomingEvents,
  comparePastEvents,
  PARTICIPATION_TYPE_LABELS,
  PARTICIPATION_TYPE_ORDER,
} from './eventMeta';

type EventEntry = CollectionEntry<'events'>;
type TypeFilter = ParticipationType | 'all';

interface Props {
  allEvents: EventEntry[];
  events: EventEntry[];
  currentType?: TypeFilter;
  buildDate?: Date;
}

const {
  allEvents,
  events,
  currentType = 'all',
  buildDate = new Date(),
} = Astro.props;

const upcoming: EventEntry[] = [];
const past: EventEntry[] = [];
for (const event of events) {
  if (classify(event.data.date as EventDate, buildDate) === 'upcoming') {
    upcoming.push(event);
  } else {
    past.push(event);
  }
}

upcoming.sort((a, b) =>
  compareUpcomingEvents(
    { date: a.data.date as EventDate, title: a.data.title },
    { date: b.data.date as EventDate, title: b.data.title },
  ),
);
past.sort((a, b) =>
  comparePastEvents(
    { date: a.data.date as EventDate, title: a.data.title },
    { date: b.data.date as EventDate, title: b.data.title },
  ),
);

const typeCounts = PARTICIPATION_TYPE_ORDER.reduce<
  Record<ParticipationType, number>
>(
  (counts, type) => {
    counts[type] = allEvents.filter(
      (e) => e.data.participation === type,
    ).length;
    return counts;
  },
  { talk: 0, livestream: 0, podcast: 0, booth: 0, paper: 0, panel: 0 },
);
---

<nav class="type-filter" aria-label="Filter events by type">
  <a
    href="/events/"
    class="type-filter-link"
    aria-current={currentType === 'all' ? 'true' : 'false'}
  >
    All <span class="type-filter-count">{allEvents.length}</span>
  </a>
  {
    PARTICIPATION_TYPE_ORDER.map((type) => (
      <a
        href={`/events/type/${type}/`}
        class="type-filter-link"
        aria-current={currentType === type ? 'true' : 'false'}
      >
        {PARTICIPATION_TYPE_LABELS[type]}{' '}
        <span class="type-filter-count">{typeCounts[type]}</span>
      </a>
    ))
  }
</nav>

<section class="event-section" aria-labelledby="events-upcoming-heading">
  <h2 id="events-upcoming-heading" class="event-section-heading">Upcoming</h2>
  {
    upcoming.length > 0 ? (
      <div class="event-grid">
        {upcoming.map((event) => (
          <EventCard event={event} />
        ))}
      </div>
    ) : (
      <p class="empty-state">No upcoming events.</p>
    )
  }
</section>

<section class="event-section" aria-labelledby="events-past-heading">
  <h2 id="events-past-heading" class="event-section-heading">Past</h2>
  {
    past.length > 0 ? (
      <div class="event-grid">
        {past.map((event) => (
          <EventCard event={event} />
        ))}
      </div>
    ) : (
      <p class="empty-state">No past events.</p>
    )
  }
</section>

<style>
  .type-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .type-filter-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 9999px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      border-color 0.15s,
      color 0.15s,
      background 0.15s;
  }

  .type-filter-link:hover,
  .type-filter-link[aria-current='true'] {
    border-color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    color: var(--sl-color-white);
  }

  .type-filter-count {
    color: var(--sl-color-gray-4);
  }

  .event-section {
    margin-bottom: 2.5rem;
  }

  .event-section-heading {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--sl-color-gray-2);
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .empty-state {
    padding: 1rem 1.125rem;
    border: 1px dashed var(--sl-color-gray-5);
    border-radius: 0.625rem;
    color: var(--sl-color-gray-3);
  }
</style>
