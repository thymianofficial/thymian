---
/**
 * CliShowcase – interactive infographic demonstrating the benefits of
 * Thymian's CLI with both interactive and non-interactive (CI) modes.
 *
 * Shows: dual-mode terminal cards, feature highlights, and mode comparison.
 * Desktop: side-by-side terminal panels with toggle.
 * Mobile:  stacked card layout.
 */

// ── Data ────────────────────────────────────────────────────────────────
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface TerminalLine {
  type: 'prompt' | 'output' | 'success' | 'error' | 'info' | 'blank' | 'interactive';
  text: string;
}

const features: Feature[] = [
  {
    icon: '⚡',
    title: 'Zero-Config Quick Start',
    description:
      'Run thymian lint against any OpenAPI spec instantly — no config file needed.',
  },
  {
    icon: '🔄',
    title: 'Interactive & CI Modes',
    description:
      'Guided prompts for developers. Flags and JSON output for CI/CD pipelines and AI agents.',
  },
  {
    icon: '🧩',
    title: 'Composable Commands',
    description:
      'Lint, test, analyze, serve — each command does one thing well and plays nicely with pipes.',
  },
  {
    icon: '📊',
    title: 'Structured JSON Output',
    description:
      'Every command supports --json for machine-readable output — perfect for LLMs, scripts, and dashboards.',
  },
  {
    icon: '🔧',
    title: 'Config Generation',
    description:
      'Scaffold configuration files and rules interactively or fully automated with --no-interactive.',
  },
  {
    icon: '🎯',
    title: 'Smart Defaults',
    description:
      'Sensible defaults out of the box. Override anything via flags, config files, or environment.',
  },
];

const interactiveLines: TerminalLine[] = [
  { type: 'prompt', text: '$ thymian generate config' },
  { type: 'blank', text: '' },
  { type: 'info', text: '? Detected specification: petstore.yaml. Use this file?' },
  { type: 'interactive', text: '  › Yes' },
  { type: 'blank', text: '' },
  { type: 'output', text: '# Thymian Configuration' },
  { type: 'output', text: '# Specification: petstore.yaml' },
  { type: 'blank', text: '' },
  { type: 'success', text: '✔ Configuration written to thymian.config.yaml' },
];

const nonInteractiveLines: TerminalLine[] = [
  { type: 'prompt', text: '$ thymian lint --json --spec openapi:./petstore.yaml' },
  { type: 'blank', text: '' },
  { type: 'output', text: '{' },
  { type: 'output', text: '  "classification": "fail",' },
  { type: 'output', text: '  "results": [{' },
  { type: 'output', text: '    "rule": "rfc9110/must-send-www-authenticate",' },
  { type: 'error', text: '    "severity": "error",' },
  { type: 'output', text: '    "location": "PUT /launches/{id} → 401"' },
  { type: 'output', text: '  }]' },
  { type: 'output', text: '}' },
];

const ciPipelineLines: TerminalLine[] = [
  { type: 'prompt', text: '$ thymian test --target-url $API_URL --json' },
  { type: 'blank', text: '' },
  { type: 'output', text: '{' },
  { type: 'output', text: '  "classification": "pass",' },
  { type: 'output', text: '  "results": [{' },
  { type: 'output', text: '    "rulesEvaluated": 34,' },
  { type: 'success', text: '    "violations": 0' },
  { type: 'output', text: '  }]' },
  { type: 'output', text: '}' },
];

const modeDetails = [
  {
    id: 'interactive',
    icon: '💻',
    label: 'Interactive',
    title: 'Developer-Friendly',
    description: 'Guided prompts, auto-detection, and a smooth developer experience for local workflows.',
    highlights: ['Spec auto-detection', 'Selection prompts', 'Colored output', 'Step-by-step wizards'],
  },
  {
    id: 'non-interactive',
    icon: '🤖',
    label: 'Non-Interactive',
    title: 'Automation-Ready',
    description: 'Deterministic flags, JSON output, and zero-prompt execution for CI/CD and AI agents.',
    highlights: ['--json flag', '--no-interactive', 'Exit codes', 'Pipe-friendly'],
  },
];
---

<section class="cs-section not-content" aria-labelledby="cs-heading">
  <!-- Header -->
  <div class="text-center mb-8 lg:mb-12">
    <h2
      id="cs-heading"
      class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3"
    >
      One CLI. Two Modes. Every Workflow.
    </h2>
    <p
      class="text-base lg:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto"
    >
      Interactive prompts guide you locally. Flags and JSON output power your
      CI/CD pipelines, scripts, and AI-driven development workflows.
    </p>
  </div>

  <!-- ═════════ Feature cards grid ═════════ -->
  <div class="cs-features">
    {
      features.map((f, i) => (
        <div
          class="cs-feature-card"
          data-animate="feature"
          data-delay={i * 80}
        >
          <span class="cs-feature-icon" aria-hidden="true">
            {f.icon}
          </span>
          <div>
            <h3 class="cs-feature-title">{f.title}</h3>
            <p class="cs-feature-desc">{f.description}</p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- ═════════ Mode toggle ═════════ -->
  <div class="cs-mode-toggle" role="tablist" aria-label="CLI mode">
    <button
      class="cs-mode-tab cs-mode-tab--active"
      role="tab"
      aria-selected="true"
      data-mode="interactive"
      id="cs-tab-interactive"
      aria-controls="cs-panel-interactive"
    >
      <span class="cs-tab-icon" aria-hidden="true">💻</span>
      Interactive
    </button>
    <button
      class="cs-mode-tab"
      role="tab"
      aria-selected="false"
      data-mode="ci"
      id="cs-tab-ci"
      aria-controls="cs-panel-ci"
    >
      <span class="cs-tab-icon" aria-hidden="true">🤖</span>
      Non-Interactive
    </button>
  </div>

  <!-- ═════════ Terminal panels ═════════ -->
  <div class="cs-terminals">
    <!-- Interactive panel -->
    <div
      class="cs-terminal-panel cs-terminal-panel--active"
      id="cs-panel-interactive"
      role="tabpanel"
      aria-labelledby="cs-tab-interactive"
    >
      <div class="cs-terminal" data-animate="terminal">
        <div class="cs-terminal-header">
          <span class="cs-dot cs-dot--red"></span>
          <span class="cs-dot cs-dot--yellow"></span>
          <span class="cs-dot cs-dot--green"></span>
          <span class="cs-terminal-title">thymian — interactive</span>
        </div>
        <div class="cs-terminal-body">
          {
            interactiveLines.map((line) => (
              <div class={`cs-line cs-line--${line.type}`}>
                {line.type === 'blank' ? <br /> : line.text}
              </div>
            ))
          }
        </div>
      </div>

      <div class="cs-panel-info">
        <h3 class="cs-panel-title">
          <span class="cs-panel-title-icon" aria-hidden="true">💻</span>
          Developer-Friendly
        </h3>
        <p class="cs-panel-desc">
          Guided prompts, auto-detection, and a smooth developer experience for
          local workflows. Thymian detects your specs, suggests configurations,
          and walks you through setup interactively.
        </p>
        <div class="cs-highlights">
          {
            ['Spec auto-detection', 'Selection prompts', 'Colored output', 'Step-by-step wizards'].map(
              (h) => (
                <span class="cs-highlight">{h}</span>
              ),
            )
          }
        </div>
      </div>
    </div>

    <!-- Non-interactive / CI panel -->
    <div
      class="cs-terminal-panel"
      id="cs-panel-ci"
      role="tabpanel"
      aria-labelledby="cs-tab-ci"
      hidden
    >
      <div class="cs-terminal-duo">
        <div class="cs-terminal" data-animate="terminal">
          <div class="cs-terminal-header">
            <span class="cs-dot cs-dot--red"></span>
            <span class="cs-dot cs-dot--yellow"></span>
            <span class="cs-dot cs-dot--green"></span>
            <span class="cs-terminal-title">lint — json output</span>
          </div>
          <div class="cs-terminal-body">
            {
              nonInteractiveLines.map((line) => (
                <div class={`cs-line cs-line--${line.type}`}>
                  {line.type === 'blank' ? <br /> : line.text}
                </div>
              ))
            }
          </div>
        </div>

        <div class="cs-terminal" data-animate="terminal">
          <div class="cs-terminal-header">
            <span class="cs-dot cs-dot--red"></span>
            <span class="cs-dot cs-dot--yellow"></span>
            <span class="cs-dot cs-dot--green"></span>
            <span class="cs-terminal-title">test — CI pipeline</span>
          </div>
          <div class="cs-terminal-body">
            {
              ciPipelineLines.map((line) => (
                <div class={`cs-line cs-line--${line.type}`}>
                  {line.type === 'blank' ? <br /> : line.text}
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="cs-panel-info">
        <h3 class="cs-panel-title">
          <span class="cs-panel-title-icon" aria-hidden="true">🤖</span>
          Automation-Ready
        </h3>
        <p class="cs-panel-desc">
          Deterministic flags, JSON output, and zero-prompt execution.
          Built for CI/CD pipelines, shell scripts, and AI coding agents
          that parse structured data.
        </p>
        <div class="cs-highlights">
          {
            ['--json flag', '--no-interactive', 'Exit codes', 'Pipe-friendly'].map(
              (h) => (
                <span class="cs-highlight">{h}</span>
              ),
            )
          }
        </div>
      </div>
    </div>
  </div>

  <!-- ═════════ Mode comparison cards ═════════ -->
  <div class="cs-modes">
    {
      modeDetails.map((mode, i) => (
        <div
          class="cs-mode-card"
          data-animate="mode-card"
          data-delay={i * 150}
        >
          <div class="cs-mode-header">
            <span class="cs-mode-icon" aria-hidden="true">
              {mode.icon}
            </span>
            <div>
              <h3 class="cs-mode-title">{mode.title}</h3>
              <span class="cs-mode-label">{mode.label}</span>
            </div>
          </div>
          <p class="cs-mode-desc">{mode.description}</p>
          <div class="cs-mode-highlights">
            {mode.highlights.map((h) => (
              <span class="cs-mode-hl">
                <code>{h}</code>
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <!-- ═════════ CTA callout ═════════ -->
  <div class="cs-callout" data-animate="callout">
    <div class="cs-callout-inner">
      <div class="cs-callout-icon-wrap" aria-hidden="true">
        <svg class="cs-callout-icon" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"></rect>
          <path d="M7 8l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          <path d="M12 16h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </div>
      <div class="cs-callout-content">
        <h3 class="cs-callout-title">Get Started in Seconds</h3>
        <p class="cs-callout-desc">
          Run your first lint with zero configuration. Generate a config file
          interactively — or go fully automated with <code>--no-interactive</code> for
          your CI pipeline.
        </p>
        <div class="cs-callout-links">
          <a href="/introduction/getting-started/" class="cs-callout-link">
            <svg
              class="cs-link-icon"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M4 1h6l4 4v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1Z"
                stroke="currentColor"
                stroke-width="1.4"></path>
              <path d="M10 1v4h4" stroke="currentColor" stroke-width="1.4"></path>
              <path
                d="M6 9h5M6 12h3"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"></path>
            </svg>
            Quick Start Guide
          </a>
          <a href="/references/cli/" class="cs-callout-link">
            <svg
              class="cs-link-icon"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <rect
                x="1"
                y="1"
                width="14"
                height="14"
                rx="2"
                stroke="currentColor"
                stroke-width="1.4"></rect>
              <path
                d="M4 5l3 3-3 3"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M9 11h3"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"></path>
            </svg>
            CLI Reference
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ Styles ═══════════════ -->
<style>
  /* ── Section wrapper ───────────────────────────────────────── */
  .cs-section {
    --cs-radius: 0.75rem;
    max-width: 80rem;
    margin-inline: auto;
    padding: 2rem 1rem;
  }
  @media (min-width: 640px) {
    .cs-section {
      padding: 2.5rem 1.5rem;
    }
  }
  @media (min-width: 1024px) {
    .cs-section {
      padding: 3rem 2rem;
    }
  }

  /* ── Feature cards grid ─────────────────────────────────────── */
  .cs-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 640px) {
    .cs-features {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .cs-features {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }

  .cs-feature-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.15rem;
    border-radius: var(--cs-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    transition: border-color 0.2s, box-shadow 0.2s;
    opacity: 0;
  }
  :global([data-theme='dark']) .cs-feature-card {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }
  .cs-feature-card.revealed {
    animation: csFadeSlideUp 0.5s ease-out forwards;
  }
  .cs-feature-card:hover {
    border-color: var(--color-accent-300);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }
  :global([data-theme='dark']) .cs-feature-card:hover {
    border-color: var(--color-accent-700);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .cs-feature-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
  }
  .cs-feature-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.25rem;
  }
  :global([data-theme='dark']) .cs-feature-title {
    color: var(--color-gray-100);
  }
  .cs-feature-desc {
    font-size: 0.78rem;
    color: var(--color-gray-600);
    line-height: 1.5;
    margin: 0;
  }
  :global([data-theme='dark']) .cs-feature-desc {
    color: var(--color-gray-400);
  }

  /* ── Mode toggle tabs ───────────────────────────────────────── */
  .cs-mode-toggle {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .cs-mode-tab {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.25rem;
    border-radius: 999px;
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    color: var(--color-gray-600);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  :global([data-theme='dark']) .cs-mode-tab {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
    color: var(--color-gray-400);
  }
  .cs-mode-tab:hover {
    border-color: var(--color-accent-300);
    color: var(--color-accent-700);
  }
  :global([data-theme='dark']) .cs-mode-tab:hover {
    border-color: var(--color-accent-700);
    color: var(--color-accent-300);
  }
  .cs-mode-tab--active {
    background: var(--color-accent-100);
    border-color: var(--color-accent-300);
    color: var(--color-accent-800);
  }
  :global([data-theme='dark']) .cs-mode-tab--active {
    background: var(--color-accent-950);
    border-color: var(--color-accent-700);
    color: var(--color-accent-300);
  }

  .cs-tab-icon {
    font-size: 1rem;
  }

  /* ── Terminal panels ────────────────────────────────────────── */
  .cs-terminals {
    margin-bottom: 2.5rem;
  }

  .cs-terminal-panel {
    display: none;
  }
  .cs-terminal-panel--active {
    display: block;
  }

  .cs-terminal-duo {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .cs-terminal-duo {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cs-terminal {
    border-radius: var(--cs-radius);
    overflow: hidden;
    border: 1px solid var(--color-gray-200);
    background: #1a1b26;
    opacity: 0;
  }
  :global([data-theme='dark']) .cs-terminal {
    border-color: var(--color-gray-700);
    background: #0d1117;
  }
  .cs-terminal.revealed {
    animation: csFadeSlideUp 0.6s ease-out forwards;
  }

  .cs-terminal-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    background: #15161e;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  :global([data-theme='dark']) .cs-terminal-header {
    background: #010409;
  }

  .cs-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
  }
  .cs-dot--red {
    background: #ef4444;
  }
  .cs-dot--yellow {
    background: #eab308;
  }
  .cs-dot--green {
    background: #22c55e;
  }

  .cs-terminal-title {
    margin-left: 0.5rem;
    font-size: 0.7rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.4);
  }

  .cs-terminal-body {
    padding: 1rem 1.25rem;
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas,
      'Liberation Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.65;
  }

  .cs-line {
    white-space: pre-wrap;
    word-break: break-all;
  }
  .cs-line--prompt {
    color: #7dd3fc;
    font-weight: 600;
  }
  .cs-line--output {
    color: rgba(255, 255, 255, 0.7);
  }
  .cs-line--success {
    color: #4ade80;
  }
  .cs-line--error {
    color: #f87171;
  }
  .cs-line--info {
    color: #a78bfa;
  }
  .cs-line--interactive {
    color: #38bdf8;
    font-weight: 600;
  }
  .cs-line--blank {
    height: 0.4rem;
  }

  /* ── Panel info (beside terminal) ───────────────────────────── */
  .cs-panel-info {
    margin-top: 1.25rem;
    padding: 1.25rem;
    border-radius: var(--cs-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
  }
  :global([data-theme='dark']) .cs-panel-info {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }

  .cs-panel-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 0.5rem;
  }
  :global([data-theme='dark']) .cs-panel-title {
    color: var(--color-gray-100);
  }
  .cs-panel-title-icon {
    font-size: 1.15rem;
  }

  .cs-panel-desc {
    font-size: 0.82rem;
    color: var(--color-gray-600);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }
  :global([data-theme='dark']) .cs-panel-desc {
    color: var(--color-gray-400);
  }

  .cs-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .cs-highlight {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--color-accent-100);
    color: var(--color-accent-800);
    border: 1px solid var(--color-accent-200);
  }
  :global([data-theme='dark']) .cs-highlight {
    background: var(--color-accent-950);
    color: var(--color-accent-300);
    border-color: var(--color-accent-800);
  }

  /* ── Mode comparison cards ──────────────────────────────────── */
  .cs-modes {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 640px) {
    .cs-modes {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cs-mode-card {
    padding: 1.25rem;
    border-radius: var(--cs-radius);
    border: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
    opacity: 0;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  :global([data-theme='dark']) .cs-mode-card {
    border-color: var(--color-gray-700);
    background: var(--color-gray-900);
  }
  .cs-mode-card.revealed {
    animation: csFadeSlideUp 0.5s ease-out forwards;
  }
  .cs-mode-card:hover {
    border-color: var(--color-accent-300);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }
  :global([data-theme='dark']) .cs-mode-card:hover {
    border-color: var(--color-accent-700);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .cs-mode-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .cs-mode-icon {
    font-size: 1.75rem;
  }
  .cs-mode-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0;
  }
  :global([data-theme='dark']) .cs-mode-title {
    color: var(--color-gray-100);
  }
  .cs-mode-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-accent-600);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  :global([data-theme='dark']) .cs-mode-label {
    color: var(--color-accent-400);
  }

  .cs-mode-desc {
    font-size: 0.82rem;
    color: var(--color-gray-600);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }
  :global([data-theme='dark']) .cs-mode-desc {
    color: var(--color-gray-400);
  }

  .cs-mode-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .cs-mode-hl {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: var(--cs-radius);
    font-size: 0.7rem;
    background: var(--color-gray-200);
    color: var(--color-gray-700);
  }
  :global([data-theme='dark']) .cs-mode-hl {
    background: var(--color-gray-800);
    color: var(--color-gray-300);
  }
  .cs-mode-hl code {
    font-size: 0.68rem;
    background: none;
    padding: 0;
  }

  /* ── Callout ────────────────────────────────────────────────── */
  .cs-callout {
    opacity: 0;
  }
  .cs-callout.revealed {
    animation: csFadeSlideUp 0.6s ease-out forwards;
  }
  .cs-callout-inner {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem 1.75rem;
    border-radius: var(--cs-radius);
    border: 1px solid var(--color-accent-200);
    background: var(--color-accent-50, var(--color-accent-100));
  }
  :global([data-theme='dark']) .cs-callout-inner {
    border-color: var(--color-accent-800);
    background: var(--color-accent-950);
  }

  .cs-callout-icon-wrap {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: var(--color-accent-200);
    color: var(--color-accent-700);
  }
  :global([data-theme='dark']) .cs-callout-icon-wrap {
    background: var(--color-accent-900);
    color: var(--color-accent-300);
  }
  .cs-callout-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .cs-callout-content {
    flex: 1;
    min-width: 0;
  }
  .cs-callout-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-accent-900);
    margin: 0 0 0.35rem;
  }
  :global([data-theme='dark']) .cs-callout-title {
    color: var(--color-accent-200);
  }
  .cs-callout-desc {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-accent-800);
    margin: 0 0 0.75rem;
  }
  :global([data-theme='dark']) .cs-callout-desc {
    color: var(--color-accent-300);
  }
  .cs-callout-desc code {
    font-size: 0.78rem;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    background: var(--color-accent-200);
    color: var(--color-accent-900);
  }
  :global([data-theme='dark']) .cs-callout-desc code {
    background: var(--color-accent-900);
    color: var(--color-accent-200);
  }

  .cs-callout-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .cs-callout-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent-700);
    text-decoration: none;
    transition: color 0.2s;
  }
  :global([data-theme='dark']) .cs-callout-link {
    color: var(--color-accent-400);
  }
  .cs-callout-link:hover {
    color: var(--color-accent-500);
    text-decoration: underline;
  }
  .cs-link-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  /* ── Animations ─────────────────────────────────────────────── */
  @keyframes csFadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes csFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-feature-card,
    .cs-terminal,
    .cs-mode-card,
    .cs-callout {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>

<!-- ═══════════════ Tab switching + scroll-triggered reveal ═══════════════ -->
<script>
  function initCliShowcase() {
    const section = document.querySelector('.cs-section');
    if (!section) return;

    // ── Tab switching ────────────────────────────────────────
    const tabs = section.querySelectorAll<HTMLElement>('.cs-mode-tab');
    const panels = section.querySelectorAll<HTMLElement>('.cs-terminal-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const mode = tab.dataset.mode;

        // Update tabs
        tabs.forEach((t) => {
          t.classList.remove('cs-mode-tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('cs-mode-tab--active');
        tab.setAttribute('aria-selected', 'true');

        // Update panels
        panels.forEach((panel) => {
          const isTarget =
            (mode === 'interactive' && panel.id === 'cs-panel-interactive') ||
            (mode === 'ci' && panel.id === 'cs-panel-ci');

          if (isTarget) {
            panel.classList.add('cs-terminal-panel--active');
            panel.removeAttribute('hidden');
            // Trigger terminal animations for newly visible panel
            panel.querySelectorAll<HTMLElement>('.cs-terminal').forEach((t) => {
              t.classList.add('revealed');
            });
          } else {
            panel.classList.remove('cs-terminal-panel--active');
            panel.setAttribute('hidden', '');
          }
        });
      });
    });

    // ── Scroll-triggered reveal ──────────────────────────────
    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    const featureCards = section.querySelectorAll<HTMLElement>('.cs-feature-card');
    const terminals = section.querySelectorAll<HTMLElement>('.cs-terminal');
    const modeCards = section.querySelectorAll<HTMLElement>('.cs-mode-card');
    const callout = section.querySelector<HTMLElement>('.cs-callout');

    if (prefersReduced) {
      featureCards.forEach((c) => c.classList.add('revealed'));
      terminals.forEach((t) => t.classList.add('revealed'));
      modeCards.forEach((c) => c.classList.add('revealed'));
      callout?.classList.add('revealed');
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          featureCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${delay}ms`;
            card.classList.add('revealed');
          });

          // Only reveal terminals in the active panel
          const activePanel = section.querySelector('.cs-terminal-panel--active');
          activePanel?.querySelectorAll<HTMLElement>('.cs-terminal').forEach((t, i) => {
            t.style.animationDelay = `${400 + i * 150}ms`;
            t.classList.add('revealed');
          });

          modeCards.forEach((card) => {
            const delay = parseInt(card.dataset.delay ?? '0', 10);
            card.style.animationDelay = `${600 + delay}ms`;
            card.classList.add('revealed');
          });

          if (callout) {
            callout.style.animationDelay = '900ms';
            callout.classList.add('revealed');
          }

          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.1 },
    );

    observer.observe(section);
  }

  initCliShowcase();
  document.addEventListener('astro:after-swap', initCliShowcase);
</script>

