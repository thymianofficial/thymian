{
  "name": "@thymian/source",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "nx run-many -t test",
    "format:check": "nx run-many -t format:check",
    "build": "nx run-many -t build",
    "lint": "nx affected:lint",
    "prepare": "husky",
    "local-registry": "nx local-registry",
    "local-publish": "node ./scripts/release.ts --local --no-dry-run",
    "check:licenses": "node scripts/check-licenses.js",
    "postinstall": "npm run check:licenses"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "nx format:write --files"
    ],
    "*.{md,json,yml,yaml}": [
      "nx format:write --files"
    ]
  },
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nx/eslint": "22.5.0",
    "@nx/eslint-plugin": "22.5.0",
    "@nx/js": "22.5.0",
    "@nx/node": "22.5.0",
    "@nx/vitest": "22.5.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "^22.15.1",
    "@vitest/coverage-v8": "^3.0.9",
    "@vitest/ui": "^3.0.9",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.1.0",
    "jsonschema2mk": "^2.1.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.1.6",
    "nx": "22.5.0",
    "oclif": "^4.22.70",
    "prettier": "^3.6.2",
    "tinyglobby": "^0.2.15",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "8.44.0",
    "verdaccio": "^6.1.0",
    "vite": "^7.1.6",
    "vitest": "^3.0.9"
  },
  "workspaces": [
    "packages/*",
    "astro-docs",
    "e2e-tests"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  },
  "volta": {
    "node": "22.19.0"
  }
}
