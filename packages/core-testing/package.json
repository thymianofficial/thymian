      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@thymian/core": "0.0.0-PLACEHOLDER"
  },
  "peerDependencies": {
    "@thymian/core": "0.0.0-PLACEHOLDER"
  }
}
