{
  "name": "http-linter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/http-linter/src",
  "projectType": "library",
  "tags": ["scope:plugin", "type:lib"],
  "// targets": "to see all targets run: nx show project @thymian/http-linter --web",
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "command": "tsc --build tsconfig.lib.json && cp src/db/sqlite/init.sql dist/db/sqlite/init.sql",
      "options": {
        "cwd": "packages/http-linter"
      }
    },
    "generate-docs": {
      "dependsOn": ["build"],
      "command": "NODE_ENV=development oclif readme --no-aliases --readme-path ../../astro-docs/src/content/docs/references/Plugins/HTTP\\ Linter/cli.md",
      "options": {
        "cwd": "packages/http-linter"
      }
    },
    "generate-schema-docs": {
      "dependsOn": ["build"],
      "command": "node scripts/generate-schema-docs.js @thymian/http-linter astro-docs/src/content/docs/references/Plugins/HTTP\\ Linter/options.md"
    }
  }
}
