{
  "name": "plugin-openapi",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin-openapi/src",
  "projectType": "library",
  "tags": ["scope:plugin", "type:lib", "npm:public"],
  "// targets": "to see all targets run: nx show project plugin-openapi --web",
  "targets": {
    "generate-docs": {
      "dependsOn": ["build"],
      "command": "NODE_ENV=development oclif readme --no-aliases --readme-path ../../astro-docs/src/content/docs/references/Plugins/OpenAPI/cli.md",
      "options": {
        "cwd": "packages/plugin-openapi"
      }
    }
  }
}
