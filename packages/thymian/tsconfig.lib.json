{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../evaluation/tsconfig.lib.json"
    },
    {
      "path": "../websocket-proxy/tsconfig.lib.json"
    },
    {
      "path": "../sampler/tsconfig.lib.json"
    },
    {
      "path": "../rfc-9110-rules/tsconfig.lib.json"
    },
    {
      "path": "../reporter/tsconfig.lib.json"
    },
    {
      "path": "../openapi/tsconfig.lib.json"
    },
    {
      "path": "../http-linter/tsconfig.lib.json"
    },
    {
      "path": "../format-validator/tsconfig.lib.json"
    },
    {
      "path": "../core/tsconfig.lib.json"
    },
    {
      "path": "../cli-common/tsconfig.lib.json"
    }
  ]
}
