{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../plugin-evaluation/tsconfig.lib.json"
    },
    {
      "path": "../plugin-websocket-proxy/tsconfig.lib.json"
    },
    {
      "path": "../plugin-sampler/tsconfig.lib.json"
    },
    {
      "path": "../rfc-9110-rules/tsconfig.lib.json"
    },
    {
      "path": "../plugin-reporter/tsconfig.lib.json"
    },
    {
      "path": "../plugin-openapi/tsconfig.lib.json"
    },
    {
      "path": "../plugin-request-dispatcher/tsconfig.lib.json"
    },
    {
      "path": "../plugin-http-linter/tsconfig.lib.json"
    },
    {
      "path": "../plugin-http-tester/tsconfig.lib.json"
    },
    {
      "path": "../plugin-http-analyzer/tsconfig.lib.json"
    },
    {
      "path": "../core/tsconfig.lib.json"
    },
    {
      "path": "../cli-common/tsconfig.lib.json"
    }
  ]
}
