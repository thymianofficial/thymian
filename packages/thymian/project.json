{
  "name": "thymian",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/thymian/src",
  "projectType": "application",
  "tags": ["scope:cli", "type:app", "npm:public"],
  "// targets": "to see all targets run: nx show project thymian --web",
  "targets": {
    "generate-docs": {
      "dependsOn": ["build"],
      "command": "NODE_ENV=development oclif readme --no-aliases --readme-path ../../astro-docs/src/content/docs/references/cli.md",
      "options": {
        "cwd": "packages/thymian"
      }
    }
  }
}
