{
  "name": "plugin-sampler",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin-sampler/src",
  "projectType": "library",
  "tags": ["scope:plugin", "type:lib", "npm:public"],
  "// targets": "to see all targets run: nx show project plugin-sampler --web",
  "targets": {
    "generate-docs": {
      "dependsOn": ["build"],
      "command": "oclif readme --no-aliases --readme-path ../../astro-docs/src/content/docs/references/Plugins/Sampler/cli.md",
      "options": {
        "cwd": "packages/plugin-sampler",
        "env": {
          "NODE_ENV": "development"
        }
      }
    },
    "generate-schema-docs": {
      "dependsOn": ["build"],
      "command": "node scripts/generate-schema-docs.js @thymian/plugin-sampler  astro-docs/src/content/docs/references/Plugins/Sampler/options.md"
    }
  }
}
