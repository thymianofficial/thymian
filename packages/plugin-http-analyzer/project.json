{
  "name": "plugin-http-analyzer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin-http-analyzer/src",
  "projectType": "library",
  "tags": ["scope:plugin", "type:lib", "npm:public"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "command": "tsc --build tsconfig.lib.json && node -e \"require('fs').cpSync('src/db/init.sql','dist/db/init.sql')\"",
      "options": {
        "cwd": "packages/plugin-http-analyzer"
      }
    },
    "generate-schema-docs": {
      "dependsOn": ["build"],
      "command": "node scripts/generate-schema-docs.js @thymian/plugin-http-analyzer  astro-docs/src/content/docs/references/Plugins/HTTP\\ Analyzer/options.md"
    }
  }
}
