{
  "name": "format-validator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/format-validator/src",
  "projectType": "library",
  "tags": ["scope:plugin", "type:lib"],
  "// targets": "to see all targets run: nx show project @thymian/format-validator --web",
  "targets": {
    "generate-docs": {
      "dependsOn": ["build"],
      "command": "NODE_ENV=development oclif readme --no-aliases --readme-path ./../../astro-docs/src/content/docs/references/Plugins/Format\\ Validator/cli.md",
      "options": {
        "cwd": "packages/format-validator"
      }
    },
    "generate-schema-docs": {
      "dependsOn": ["build"],
      "command": "node scripts/generate-schema-docs.js @thymian/format-validator  astro-docs/src/content/docs/references/Plugins/Format\\ Validator/options.md"
    }
  }
}
