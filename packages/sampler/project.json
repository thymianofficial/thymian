{
  "name": "sampler",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/sampler/src",
  "projectType": "library",
  "tags": ["scope:plugin", "type:lib"],
  "// targets": "to see all targets run: nx show project @thymian/sampler --web",
  "targets": {
    "generate-docs": {
      "command": "NODE_ENV=development oclif readme --no-aliases --readme-path ../../astro-docs/src/content/docs/references/Plugins/Sampler/cli.md",
      "options": {
        "cwd": "packages/sampler"
      }
    },
    "generate-schema-docs": {
      "dependsOn": ["build"],
      "command": "node scripts/generate-schema-docs.js @thymian/sampler  astro-docs/src/content/docs/references/Plugins/Sampler/options.md"
    }
  }
}
