{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["plugins"],
  "additionalProperties": false,
  "properties": {
    "autoload": {
      "type": "boolean"
    },
    "logLevel": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error", "silent"]
    },
    "specifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "location"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string"
          },
          "location": {},
          "options": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "traffic": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "location"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string"
          },
          "location": {},
          "options": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "ruleSets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ruleSeverity": {
      "type": "string",
      "enum": ["off", "error", "warn", "hint"]
    },
    "targetUrl": {
      "type": "string",
      "description": "Override the target URL for all test requests. When set, all requests are sent to this origin instead of the servers defined in the specification."
    },
    "rules": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "enum": ["error", "warn", "hint", "off"]
          },
          {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "severity": {
                "type": "string",
                "enum": ["error", "warn", "hint", "off"]
              },
              "options": {
                "type": "object",
                "additionalProperties": true
              },
              "skipOrigins": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      }
    },
    "plugins": {
      "type": "object",
      "nullable": false,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "verbose": {
            "type": "boolean"
          },
          "options": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
